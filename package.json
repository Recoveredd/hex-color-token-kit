{
  "name": "hex-color-token-kit",
  "version": "0.1.0",
  "description": "Extract and validate CSS hex color tokens with spans and diagnostics.",
  "keywords": [
    "hex-color",
    "css",
    "colors",
    "parser",
    "validator",
    "diagnostics",
    "typescript",
    "browser",
    "developer-tools"
  ],
  "type": "module",
  "sideEffects": false,
  "license": "MPL-2.0",
  "author": "Recoveredd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Recoveredd/hex-color-token-kit.git"
  },
  "bugs": {
    "url": "https://github.com/Recoveredd/hex-color-token-kit/issues"
  },
  "homepage": "https://github.com/Recoveredd/hex-color-token-kit#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.17.24",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
